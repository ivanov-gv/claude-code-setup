{
  "name": "cc-golang-dind",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "shutdownAction": "none",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": "false"
    },
    "ghcr.io/stu-bell/devcontainer-features/claude-code:0": {},
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/azutake/devcontainer-features/go-packages-install:0": {
      "PACKAGES": "golang.org/x/tools/gopls@latest github.com/ivanov-gv/contribute/cmd/contribute@latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/w3cj/devcontainer-features/firewall:latest": {
      "hosts": "proxy.golang.org,sum.golang.org,storage.googleapis.com,golang.org,cloudflarestorage.com,download.docker.com",
      "githubIps": true,
      "githubDomains": true,
      "anthropicIps": true,
      "anthropicApi": true,
      "googleCloudIps": true,
      "cloudflareIps": true,
      "dockerRegistry": true,
      "debianPackages": true,
      "ubuntuPackages": true,
      "claudeCode": true
    },
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "dtach"
    },
    "../sandbox-init": {}
  }
}
